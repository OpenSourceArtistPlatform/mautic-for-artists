# =============================================================================
# Mautic for Artists — Configuration
# =============================================================================
# Copy this file to .env and customize the values below.
# Run ./setup.sh for an interactive setup wizard that generates this for you.
# =============================================================================

# --- Artist Branding ---
ARTIST_NAME="My Artist Name"
ARTIST_BRAND_COLOR="#6C63FF"
ARTIST_LOGO_URL="/media/images/placeholder-logo.png"
ARTIST_DOMAIN=localhost

# --- Mautic Admin Account ---
MAUTIC_ADMIN_EMAIL=admin@example.com
MAUTIC_ADMIN_PASSWORD=changeme
MAUTIC_ADMIN_USERNAME=admin

# --- Mautic URL ---
# The public URL where Mautic will be accessible
MAUTIC_URL=http://localhost:8080
MAUTIC_PORT=8080

# --- Email / SMTP ---
# Mautic uses Symfony Mailer DSN format. Examples:
#
# Mailgun:     smtp://postmaster@mg.yourdomain.com:YOUR_MAILGUN_PASSWORD@smtp.mailgun.org:587
# Amazon SES:  smtp://YOUR_SES_USERNAME:YOUR_SES_PASSWORD@email-smtp.us-east-1.amazonaws.com:587
# SendGrid:    smtp://apikey:YOUR_SENDGRID_API_KEY@smtp.sendgrid.net:587
# Brevo:       smtp://YOUR_BREVO_EMAIL:YOUR_BREVO_SMTP_KEY@smtp-relay.brevo.com:587
# Gmail:       smtp://your@gmail.com:YOUR_APP_PASSWORD@smtp.gmail.com:587
#
# Leave as null://null to configure later in Mautic UI
MAUTIC_MAILER_DSN=null://null

# --- Database (auto-generated by setup.sh) ---
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=mautic
MYSQL_USER=mautic
MYSQL_PASSWORD=changeme_db
