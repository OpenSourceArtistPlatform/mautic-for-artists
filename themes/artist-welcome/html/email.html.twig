<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>{subject}</title>
    <!--[if mso]>
    <noscript>
        <xml>
            <o:OfficeDocumentSettings>
                <o:PixelsPerInch>96</o:PixelsPerInch>
            </o:OfficeDocumentSettings>
        </xml>
    </noscript>
    <![endif]-->
    <style type="text/css">
        body {
            margin: 0;
            padding: 0;
            -webkit-text-size-adjust: 100%;
            -ms-text-size-adjust: 100%;
        }
        table, td {
            border-collapse: collapse;
            mso-table-lspace: 0pt;
            mso-table-rspace: 0pt;
        }
        img {
            border: 0;
            height: auto;
            line-height: 100%;
            outline: none;
            text-decoration: none;
            -ms-interpolation-mode: bicubic;
        }
        a {
            color: {{BRAND_COLOR}};
            text-decoration: none;
        }
        .body-wrapper {
            background-color: #f4f4f7;
            font-family: Ubuntu, Helvetica, Arial, sans-serif;
            font-size: 16px;
            line-height: 1.6;
            color: #3c4043;
        }
        .content-cell {
            background-color: #ffffff;
        }
        .cta-button {
            display: inline-block;
            background-color: {{BRAND_COLOR}};
            color: #ffffff !important;
            font-family: Ubuntu, Helvetica, Arial, sans-serif;
            font-size: 16px;
            font-weight: 700;
            line-height: 1;
            text-decoration: none;
            text-transform: none;
            padding: 14px 32px;
            border-radius: 6px;
            mso-padding-alt: 0;
        }
        .cta-button:hover {
            opacity: 0.9;
        }
        @media only screen and (max-width: 600px) {
            .email-container {
                width: 100% !important;
                max-width: 100% !important;
            }
            .content-padding {
                padding-left: 20px !important;
                padding-right: 20px !important;
            }
            .mobile-full-width {
                width: 100% !important;
                display: block !important;
            }
        }
    </style>
</head>
<body class="body-wrapper" style="margin:0; padding:0; background-color:#f4f4f7;">

<!-- Pre-header (hidden text for email clients) -->
<div style="display:none; font-size:1px; color:#f4f4f7; line-height:1px; max-height:0; max-width:0; opacity:0; overflow:hidden;">
    {subject}
    &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847;
</div>

<center style="width:100%; background-color:#f4f4f7;">
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color:#f4f4f7;">
<tr>
<td align="center" valign="top" style="padding: 20px 0;">

<!-- Web view link -->
<table role="presentation" class="email-container" cellpadding="0" cellspacing="0" border="0" width="600" style="max-width:600px; margin:0 auto;">
    <tr>
        <td align="center" style="padding: 10px 20px; font-family: Ubuntu, Helvetica, Arial, sans-serif; font-size: 12px; color: #94a3b8;">
            Not displaying correctly? <a href="{webview_url}" style="color: {{BRAND_COLOR}}; text-decoration: underline;">View in browser</a>
        </td>
    </tr>
</table>

<!-- Logo Header -->
<table role="presentation" class="email-container" cellpadding="0" cellspacing="0" border="0" width="600" style="max-width:600px; margin:0 auto;">
    <tr>
        <td align="center" style="padding: 30px 20px 20px 20px; background-color: #ffffff; border-radius: 8px 8px 0 0;">
            <img src="{{LOGO_URL}}" alt="Logo" width="180" style="display:block; width:180px; max-width:180px; height:auto; border:0;">
        </td>
    </tr>
</table>

<!-- Main Content -->
<table role="presentation" class="email-container" cellpadding="0" cellspacing="0" border="0" width="600" style="max-width:600px; margin:0 auto;">
    <tr>
        <td class="content-cell content-padding" style="background-color:#ffffff; padding: 10px 48px 40px 48px;">

            <!-- Welcome Headline -->
            <h1 style="margin:0 0 16px 0; font-family:Ubuntu, Helvetica, Arial, sans-serif; font-size:24px; font-weight:700; line-height:1.3; color:{{BRAND_COLOR}}; text-align:center;">
                Welcome to the family, {contactfield=firstname}!
            </h1>

            <!-- Body Text -->
            <p style="margin:0 0 20px 0; font-family:Ubuntu, Helvetica, Arial, sans-serif; font-size:16px; line-height:1.6; color:#3c4043; text-align:left;">
                You're officially part of the inner circle. As a member, you'll be the first to know about everything — before anyone else. Here's what's coming your way:
            </p>

            <!-- Bullet List -->
            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin: 0 0 24px 0;">
                <tr>
                    <td style="padding: 8px 0 8px 0; font-family: Ubuntu, Helvetica, Arial, sans-serif; font-size: 16px; line-height: 1.6; color: #3c4043;">
                        <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                                <td valign="top" style="padding-right: 12px; color: {{BRAND_COLOR}}; font-size: 18px; font-weight: 700;">&#8226;</td>
                                <td style="font-family: Ubuntu, Helvetica, Arial, sans-serif; font-size: 16px; line-height: 1.6; color: #3c4043;">
                                    <strong>Exclusive release updates</strong> &mdash; Be the first to hear new music before it drops on streaming platforms.
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
                <tr>
                    <td style="padding: 8px 0 8px 0; font-family: Ubuntu, Helvetica, Arial, sans-serif; font-size: 16px; line-height: 1.6; color: #3c4043;">
                        <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                                <td valign="top" style="padding-right: 12px; color: {{BRAND_COLOR}}; font-size: 18px; font-weight: 700;">&#8226;</td>
                                <td style="font-family: Ubuntu, Helvetica, Arial, sans-serif; font-size: 16px; line-height: 1.6; color: #3c4043;">
                                    <strong>Early ticket access</strong> &mdash; Get presale codes and first dibs on tickets before they go public.
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
                <tr>
                    <td style="padding: 8px 0 8px 0; font-family: Ubuntu, Helvetica, Arial, sans-serif; font-size: 16px; line-height: 1.6; color: #3c4043;">
                        <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                                <td valign="top" style="padding-right: 12px; color: {{BRAND_COLOR}}; font-size: 18px; font-weight: 700;">&#8226;</td>
                                <td style="font-family: Ubuntu, Helvetica, Arial, sans-serif; font-size: 16px; line-height: 1.6; color: #3c4043;">
                                    <strong>Behind-the-scenes content</strong> &mdash; Studio sessions, creative process, and stories you won't find anywhere else.
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
                <tr>
                    <td style="padding: 8px 0 8px 0; font-family: Ubuntu, Helvetica, Arial, sans-serif; font-size: 16px; line-height: 1.6; color: #3c4043;">
                        <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                                <td valign="top" style="padding-right: 12px; color: {{BRAND_COLOR}}; font-size: 18px; font-weight: 700;">&#8226;</td>
                                <td style="font-family: Ubuntu, Helvetica, Arial, sans-serif; font-size: 16px; line-height: 1.6; color: #3c4043;">
                                    <strong>Special merch deals</strong> &mdash; Exclusive drops and discounts only for the inner circle.
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
            </table>

            <!-- CTA Button -->
            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                <tr>
                    <td align="center" style="padding: 10px 0 20px 0;">
                        <!--[if mso]>
                        <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w="urn:schemas-microsoft-com:office:word" style="height:48px;v-text-anchor:middle;width:220px;" arcsize="13%" fillcolor="{{BRAND_COLOR}}" stroke="f">
                            <w:anchorlock/>
                            <center style="color:#ffffff;font-family:Ubuntu,Helvetica,Arial,sans-serif;font-size:16px;font-weight:bold;">Listen Now</center>
                        </v:roundrect>
                        <![endif]-->
                        <!--[if !mso]><!-->
                        <a href="#" class="cta-button" style="display:inline-block; background-color:{{BRAND_COLOR}}; color:#ffffff; font-family:Ubuntu, Helvetica, Arial, sans-serif; font-size:16px; font-weight:700; text-decoration:none; padding:14px 32px; border-radius:6px;">
                            Listen Now
                        </a>
                        <!--<![endif]-->
                    </td>
                </tr>
            </table>

        </td>
    </tr>
</table>

<!-- Divider -->
<table role="presentation" class="email-container" cellpadding="0" cellspacing="0" border="0" width="600" style="max-width:600px; margin:0 auto;">
    <tr>
        <td style="background-color:#ffffff; padding: 0 48px;">
            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                <tr>
                    <td style="border-top: 2px solid {{BRAND_COLOR}}; font-size: 1px; line-height: 1px;">&nbsp;</td>
                </tr>
            </table>
        </td>
    </tr>
</table>

<!-- Social Links Row -->
<table role="presentation" class="email-container" cellpadding="0" cellspacing="0" border="0" width="600" style="max-width:600px; margin:0 auto;">
    <tr>
        <td align="center" style="background-color:#ffffff; padding: 24px 48px 30px 48px; border-radius: 0 0 8px 8px;">
            <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                <tr>
                    <td align="center" style="padding: 0 8px;">
                        <a href="#" style="color: #64748b; text-decoration: none; font-family: Ubuntu, Helvetica, Arial, sans-serif; font-size: 13px;">Spotify</a>
                    </td>
                    <td style="color: #cbd5e1; font-family: Ubuntu, Helvetica, Arial, sans-serif; font-size: 13px;">|</td>
                    <td align="center" style="padding: 0 8px;">
                        <a href="#" style="color: #64748b; text-decoration: none; font-family: Ubuntu, Helvetica, Arial, sans-serif; font-size: 13px;">Instagram</a>
                    </td>
                    <td style="color: #cbd5e1; font-family: Ubuntu, Helvetica, Arial, sans-serif; font-size: 13px;">|</td>
                    <td align="center" style="padding: 0 8px;">
                        <a href="#" style="color: #64748b; text-decoration: none; font-family: Ubuntu, Helvetica, Arial, sans-serif; font-size: 13px;">YouTube</a>
                    </td>
                    <td style="color: #cbd5e1; font-family: Ubuntu, Helvetica, Arial, sans-serif; font-size: 13px;">|</td>
                    <td align="center" style="padding: 0 8px;">
                        <a href="#" style="color: #64748b; text-decoration: none; font-family: Ubuntu, Helvetica, Arial, sans-serif; font-size: 13px;">TikTok</a>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>

<!-- Dark Footer -->
<table role="presentation" class="email-container" cellpadding="0" cellspacing="0" border="0" width="600" style="max-width:600px; margin:0 auto;">
    <tr>
        <td align="center" style="background-color:#1e293b; padding: 30px 48px; border-radius: 8px; margin-top: 8px;">
            <p style="margin:0 0 12px 0; font-family:Ubuntu, Helvetica, Arial, sans-serif; font-size:13px; line-height:1.5; color:#94a3b8; text-align:center;">
                You're receiving this because you joined the fan list. If you'd rather not hear from us, you can unsubscribe below.
            </p>
            <p style="margin:0; font-family:Ubuntu, Helvetica, Arial, sans-serif; font-size:13px; line-height:1.5; color:#94a3b8; text-align:center;">
                {unsubscribe_text}
            </p>
        </td>
    </tr>
</table>

<!-- Bottom Spacing -->
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="600" style="max-width:600px; margin:0 auto;">
    <tr>
        <td style="padding: 20px 0; font-size: 1px; line-height: 1px;">&nbsp;</td>
    </tr>
</table>

</td>
</tr>
</table>
</center>

</body>
</html>
